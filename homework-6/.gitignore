# Virtual environment
.venv/

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Transient runtime pipeline state (regenerated by `python integrator.py`).
# The immutable per-run capture under shared/runs/ is evidence and is kept.
shared/input/
shared/processing/
shared/output/
shared/results/
shared/audit.log

# Keep the immutable per-run capture (results + audit.log + manifest) as evidence,
# overriding the repo-root "*.log" rule for run-folder audit logs.
!shared/runs/
!shared/runs/**
!shared/runs/**/audit.log
